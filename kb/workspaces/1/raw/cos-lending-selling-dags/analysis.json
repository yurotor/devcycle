      ]
    },
    {
      "severity": "high",
      "category": "security",
      "title": "Hard-coded AWS region",
      "description": "AWS region is hard-coded as 'us-east-1' in log configuration which reduces portability and could create issues if deployed to a different region. Region should be retrieved from environment or configuration.",
      "files": [
        "dags/projects/utils/flyway_task_factory.py",
